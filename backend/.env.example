PORT=5000

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=bware_ai

# Authentication
JWT_SECRET=your_super_secure_32_character_secret_key_here
JWT_EXPIRES_IN=7d

# Services
NLP_SERVICE_URL=https://eyesee11-b-ware.hf.space
# Redis Cloud URL — get yours from https://redis.io/try-free
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:your_redis_password@your-redis-host:your-redis-port

# CORS — URL of your frontend app
FRONTEND_URL=http://localhost:3000

# News API key from https://newsapi.org (optional — trending feed won't run without it)
NEWS_API_KEY=your_newsapi_key_here

GOOGLE_FACT_CHECK_API_KEY=your_key_here